# PostgreSQL接続文字列 (Vercel Postgres / Supabase / Neon など)
DATABASE_URL="postgresql://user:password@localhost:5432/business_improvement?schema=public"

# Auth.js の署名用シークレット (openssl rand -base64 32 で生成)
AUTH_SECRET="change-me"

# 本番環境のURL (Vercelにデプロイする場合は自動設定されるため通常は不要)
# AUTH_URL="https://your-app.vercel.app"

# 初期管理者アカウント (npm run db:seed で使用)
SEED_ADMIN_NAME="管理者"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
